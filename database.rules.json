{
  "rules": {
    ".read": false,
    ".write": false,
    "ballots": {
      ".read": true,
      "$voterId": {
        ".write": true,
        ".validate": "newData.hasChild('ratings')",
        "ratings": {
          "$face": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10"
          }
        },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    }
  }
}
